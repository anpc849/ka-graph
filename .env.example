# KaGraph / KaTrace Studio Local Environment Example
# Copy this file to .env and fill in your values

# ---------------------------------------------------------
# 1. LLM Proxy Configuration (Required for Kaggle Models)
# ---------------------------------------------------------
# The URL to the Kaggle Model Proxy endpoint
MODEL_PROXY_URL=https://mp-staging.kaggle.net/models/openapi

# Your Kaggle Model Proxy API Key
MODEL_PROXY_API_KEY=your_api_key_here

# ---------------------------------------------------------
# 2. KaTrace Studio (Optional Overrides)
# ---------------------------------------------------------
# Backend URL used by the tracer (if not default)
# KATRACE_BACKEND_URL=http://localhost:8000
